# Shared
NODE_ENV=development
LOG_LEVEL=info
PORT=1000

# API
RIOT_API_KEY=RGAPI-your-key
RIOT_BASE_URL=https://americas.api.riotgames.com
REDIS_URL=redis://localhost:6379
REQUEST_TIMEOUT_MS=10000
CACHE_DEFAULT_TTL_SECONDS=120

# Web
VITE_API_URL=http://localhost:1000/api

# Optional AI integrations (future modules)
AI_PROVIDER=rules
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama3.2:3b
GEMINI_API_KEY=your-gemini-key
OPENAI_API_KEY=your-openai-key

# Optional persistence (future modules)
DATABASE_URL=postgres://user:password@host:5432/postgres?sslmode=require
